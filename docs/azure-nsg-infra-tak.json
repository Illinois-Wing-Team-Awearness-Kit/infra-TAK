{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "infra-TAK App Node NSG — aligned with deployment as of v0.9.15-alpha (2026-05). Public streaming via MediaMTX (8554/8322/8890/8000-8001) and CloudTAK Media (18554/11935/18890). All admin UIs (Authentik 9000/9443, TAK Portal 3000, Node-RED 1880, MediaMTX webedit 5080 / HLS 8888 / API 9898, CloudTAK api/tiles/media-admin 5000/5002/9997/18888/9002) are bound to 127.0.0.1 on the host and reached only via Caddy on 443 with Authentik forward_auth — no NSG rule required. See docs/PORT-EXPOSURE-POLICY.md for the tier model.",
  "parameters": {
    "nsgName": {
      "type": "string",
      "defaultValue": "tak-app-nsg",
      "metadata": {
        "description": "Name of the existing NSG to update (App Node)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "adminSourceIP": {
      "type": "string",
      "defaultValue": "*",
      "metadata": {
        "description": "Your public IP address in CIDR notation (e.g. 1.2.3.4/32) for SSH and console access. Use * to allow any (not recommended for production)."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-04-01",
      "name": "[parameters('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "SSH",
            "properties": {
              "priority": 100,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[parameters('adminSourceIP')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22",
              "description": "SSH - restricted to admin IP"
            }
          },
          {
            "name": "HTTP",
            "properties": {
              "priority": 110,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "80",
              "description": "HTTP - Caddy ACME HTTP-01 challenge and redirect to HTTPS"
            }
          },
          {
            "name": "HTTPS",
            "properties": {
              "priority": 120,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443",
              "description": "HTTPS - Caddy terminates TLS for CloudTAK, TAK Portal, Node-RED, Authentik, MediaMTX webedit/HLS"
            }
          },
          {
            "name": "infra-TAK-console",
            "properties": {
              "priority": 130,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "[parameters('adminSourceIP')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "5001",
              "description": "infra-TAK management console - direct-IP backdoor (admin only)"
            }
          },
          {
            "name": "TAK-clients",
            "properties": {
              "priority": 140,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8089",
              "description": "TAK Server - ATAK/WinTAK/iTAK client connections (TLS, client-cert)"
            }
          },
          {
            "name": "TAK-admin-cert",
            "properties": {
              "priority": 150,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8443",
              "description": "TAK Server admin WebGUI - client certificate auth"
            }
          },
          {
            "name": "TAK-admin-ldap",
            "properties": {
              "priority": 160,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8446",
              "description": "TAK Server admin WebGUI - LDAP/password auth (Let's Encrypt cert via Caddy)"
            }
          },
          {
            "name": "MediaMTX-RTSP",
            "properties": {
              "priority": 170,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8554",
              "description": "MediaMTX - RTSP drone/video stream (basic-auth + token)"
            }
          },
          {
            "name": "MediaMTX-RTSPS",
            "properties": {
              "priority": 180,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8322",
              "description": "MediaMTX - RTSPS (TLS-wrapped RTSP) for encrypted drone/video streams"
            }
          },
          {
            "name": "MediaMTX-SRT",
            "properties": {
              "priority": 190,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8890",
              "description": "MediaMTX - SRT streaming clients (UDP)"
            }
          },
          {
            "name": "MediaMTX-RTP",
            "properties": {
              "priority": 200,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8000",
              "description": "MediaMTX - RTP companion port for RTSP (UDP)"
            }
          },
          {
            "name": "MediaMTX-RTCP",
            "properties": {
              "priority": 210,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8001",
              "description": "MediaMTX - RTCP companion port for RTSP (UDP)"
            }
          },
          {
            "name": "CloudTAK-Media-RTSP",
            "properties": {
              "priority": 220,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "18554",
              "description": "CloudTAK Media - RTSP clients for CloudTAK video tab"
            }
          },
          {
            "name": "CloudTAK-Media-RTMP",
            "properties": {
              "priority": 230,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "11935",
              "description": "CloudTAK Media - RTMP publishers for CloudTAK video tab"
            }
          },
          {
            "name": "CloudTAK-Media-SRT",
            "properties": {
              "priority": 240,
              "protocol": "Udp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "18890",
              "description": "CloudTAK Media - SRT clients for CloudTAK video tab (UDP)"
            }
          },
          {
            "name": "TAK-Server-plaintext-disabled",
            "properties": {
              "priority": 300,
              "protocol": "Tcp",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "8087",
              "description": "TAK Server plaintext input - disabled by default, deny explicitly (defense-in-depth)"
            }
          },
          {
            "name": "PostgreSQL-never-public",
            "properties": {
              "priority": 310,
              "protocol": "Tcp",
              "access": "Deny",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "5432",
              "description": "PostgreSQL - never publicly reachable on the App Node. CloudTAK PostGIS and Authentik PG are Docker-internal only. Deny explicitly (PG_MEM incident, v0.9.11)."
            }
          }
        ]
      }
    }
  ]
}
