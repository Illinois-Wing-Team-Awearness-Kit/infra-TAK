# ── TAK Server connection ─────────────────────────────────────────────────────
TAK_HOST=localhost
TAK_ADMIN_PORT=8443
TAK_ADMIN_USER=webadmin
TAK_ADMIN_PASS=your-tak-webadmin-password
TAK_VERIFY_SSL=false          # set true if TAK Server has a valid cert
TAK_CREATOR_UID=cap-portal    # UID stamped on DataSync missions created by portal

# ── Portal session ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-generate-a-random-hex-key

# ── Optional: session store paths ─────────────────────────────────────────────
SESSION_STORE_PATH=.session_store.enc
SESSION_KEY_PATH=.session.key

# ── Optional: listening port ───────────────────────────────────────────────────
PORTAL_PORT=5002

# ── SMTP / Email (for credential delivery) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=CAP TAK Portal <your-gmail@gmail.com>

# ── TAK Portal integration (group + user provisioning) ────────────────────────
# Internal URL of TAK Portal (called server-to-server, bypassing Authentik proxy)
TAK_PORTAL_URL=http://localhost:3000
# Authentik admin credentials — sent as proxy headers on every portal API call
TAK_PORTAL_ADMIN_USER=akadmin
TAK_PORTAL_ADMIN_UID=your-authentik-admin-uid-here
TAK_PORTAL_ADMIN_GROUPS=ak-admins
# Agency suffix appended to badge numbers to form usernames (e.g. 26-t-4766cap-il)
TAK_AGENCY_SUFFIX=cap-il
# Email stamped on every provisioned mission account
TAK_MISSION_EMAIL=ilwg.tak@gmail.com
